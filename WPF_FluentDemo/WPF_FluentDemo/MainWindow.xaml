<Window x:Class="WPF_FluentDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_FluentDemo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Slider Width="100" VerticalAlignment="Center"></Slider>

        <Border Width="300" Height="300" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="{DynamicResource AccentFillColorDefaultBrush}"></Border>
    </Grid>
</Window>
