<tianxia:BlurWindow x:Class="WPFGetRawInputData.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tianxia="clr-namespace:TianXiaTech;assembly=BlurWindow"
        xmlns:local="clr-namespace:WPFGetRawInputData"
        xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="400" Topmost="True">
    <Window.Background>
        <ImageBrush ImageSource="bg.jpeg" Stretch="UniformToFill" Opacity=".4"></ImageBrush>
    </Window.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <ListBox Name="listbox" Background="Transparent"></ListBox>

        <Button Content="注册" Grid.Row="1" Width="88" Height="28" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0" Click="Button_Click"></Button>
    </Grid>
</tianxia:BlurWindow>
